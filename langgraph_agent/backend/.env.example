# THETA Backend (LangGraph Agent) 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 允许的来源 (前端地址)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.railway.app

# 数据目录配置
DATA_DIR=./data
RESULT_DIR=./result

# 模拟模式 (Railway 部署时建议开启，避免 GPU 依赖)
SIMULATION_MODE=true

# 日志级别
LOG_LEVEL=INFO

# ----- Qwen / DashScope（AI 助手对话）-----
# 从 https://dashscope.console.aliyun.com/ 获取 API Key；不填则 AI 助手使用规则兜底
# QWEN_API_KEY=sk-你的DashScope密钥
# QWEN_MODEL=qwen-turbo

# ----- 阿里云统一凭证 -----
# 同时用于 OSS 和 DLC 服务，配置后自动启用 OSS 直传 + DLC 训练
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_CLOUD_REGION=cn-shanghai

# ----- 阿里云 OSS（文件存储） -----
# OSS_BUCKET=theta-prod-20260123
# OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# ----- 阿里云 PAI-DLC（训练集群） -----
# DLC_WORKSPACE_ID=464377
# OSS_DATASET_ID=d-xxx
# DLC_TRAINING_IMAGE=dsw-registry-vpc.cn-shanghai.cr.aliyuncs.com/pai/pytorch-training:2.7-gpu-py312-cu128-ubuntu24.04
# DLC_INSTANCE_TYPE=ecs.gn7i-c8g1.2xlarge

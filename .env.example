# THETA 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# start.sh 和 langgraph_agent 后端都会自动加载此文件

# ==================== 基础配置 ====================
DEBUG=false
SIMULATION_MODE=false
DOMAIN=localhost

# ==================== 数据库 ====================
POSTGRES_PASSWORD=theta123

# ==================== 认证 ====================
SECRET_KEY=your-secure-secret-key-change-in-production

# ==================== Qwen API (聊天功能) ====================
QWEN_API_KEY=sk-your-qwen-api-key

# ==================== 阿里云统一凭证 ====================
# 用于 OSS、DLC 等所有阿里云服务
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_CLOUD_REGION=cn-shanghai

# ==================== 阿里云 OSS (文件存储) ====================
OSS_BUCKET=theta-prod-20260123
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# ==================== 阿里云 PAI-DLC (训练集群) ====================
DLC_WORKSPACE_ID=464377
OSS_DATASET_ID=d-xxx
# DLC 训练镜像（使用 pai 命名空间的 dsw-registry-vpc）
DLC_TRAINING_IMAGE=dsw-registry-vpc.cn-shanghai.cr.aliyuncs.com/pai/pytorch-training:2.7-gpu-py312-cu128-ubuntu24.04
# DLC 实例规格
DLC_INSTANCE_TYPE=ecs.gn7i-c8g1.2xlarge

# ==================== 阿里云 PAI-EAS (推理服务，可选) ====================
# EAS_ENDPOINT=https://your-eas-endpoint.cn-hongkong.pai-eas.aliyuncs.com
# EAS_TOKEN=your-eas-token
